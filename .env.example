# ─────────────────────────────────────────────────────────────────────────────
# War Machine — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Python scripts use SUPABASE_SERVICE_ROLE_KEY (bypasses RLS)
# Next.js app uses both public + service role
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ── OpenRouter (tiered AI routing) ────────────────────────────────────────────
# Recruit/Lieutenant → mistral/mistral-7b-instruct:free (free)
# Admiral           → deepseek/deepseek-chat (paid, high quality)
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: force a specific model for all ranks
# OPENROUTER_MODEL=mistral/mistral-7b-instruct:free

# ── Resend (email delivery) ────────────────────────────────────────────────────
# From: verified domain in Resend dashboard
RESEND_API_KEY=re_...
FROM_EMAIL=recon@yourdomain.com
FROM_NAME=Shadow Agency — Recon Division

# ── App URLs ───────────────────────────────────────────────────────────────────
# Used for CTA links in cold emails and click-tracker redirects
NEXT_PUBLIC_APP_URL=https://your-war-machine.vercel.app
APP_BASE_URL=https://your-war-machine.vercel.app
TRACK_BASE_URL=https://your-war-machine.vercel.app/api/track

# ── Scraper settings ───────────────────────────────────────────────────────────
MAX_LEADS_PER_RUN=50
HEADLESS=true
EMAIL_DELAY_SECONDS=2.5
SCRAPE_DELAY_SECONDS=1.5

# ── ForgeGuard ↔ Railway handshake ─────────────────────────────────────────────
# Must byte-match forgeguard-ai Vercel INTERNAL_SCAN_TOKEN
INTERNAL_SCAN_TOKEN=your-shared-internal-scan-token
